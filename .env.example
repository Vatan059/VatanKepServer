OPCUA_ENDPOINT=opc.tcp://192.168.5.95:49320

# Min/Max sinir asimi e-posta uyarilari icin SMTP ayarlari.
# Bos birakilirsa e-posta gonderilmez, sadece konsola yazilir.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Birden fazla alici icin virgulle ayirin: a@vatan.com.tr,b@vatan.com.tr
ALERT_TO=
# Ayni tag surekli sinir disindaysa kac dakikada bir hatirlatma maili atilsin
ALERT_REPEAT_MINUTES=30
